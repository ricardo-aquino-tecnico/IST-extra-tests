core
core.*
vgcore.*

# Ficheiros do Python (Scripts de stress)
__pycache__/
*.pyc

# Ficheiros temporários de editores de terminal (Vim/Nano/Linux)
*.swp
*.swo
*~

# Ficheiros de sistema (macOS)
*.dSYM/
.DS_Store

# IDEs, Editores de texto e ficheiros comprimidos (Submissão)
